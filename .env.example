# ════════════════════════════════════════════════
#  MinePanel — .env.example
#  Скопіюй у .env і заповни реальними значеннями
# ════════════════════════════════════════════════

# ── ОБОВ'ЯЗКОВІ ──────────────────────────────────

# Мінімум 32 символи. Генерація:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ЗАМІНИТИ_НА_ВИПАДКОВИЙ_РЯДОК_32_СИМВОЛИ

# Логін і пароль адміна (пароль мінімум 12 символів)
ADMIN_USER=admin
ADMIN_PASS=ЗАМІНИТИ_НА_СИЛЬНИЙ_ПАРОЛЬ

# ── НЕОБОВ'ЯЗКОВІ ────────────────────────────────

# URL твого сайту для CORS та CSRF захисту
# Залиш порожнім якщо розробка на localhost
ALLOWED_ORIGIN=https://yourserver.com

# false — якщо тестуєш на localhost без HTTPS
COOKIE_SECURE=true

# Рядок підключення до БД (якщо PostgreSQL/MySQL)
# Якщо порожньо — використовується SQLite (data/store.db)
# DB_URL=postgresql://user:password@localhost/minepanel
DB_URL=
